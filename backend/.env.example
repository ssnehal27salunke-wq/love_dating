# ── Server ──────────────────────────────────────
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:3000
MOBILE_URL=exp://localhost:8081

# ── PostgreSQL (Supabase / Neon.tech / Local) ────
# Option A: Connection string (recommended for Supabase/Neon)
# DATABASE_URL=postgresql://user:password@host:5432/lovemarriage
# Option B: Individual fields (local PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lovemarriage
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ── MongoDB (Atlas Free Tier / Local) ────────────
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/lovemarriage_chat
MONGO_URI=mongodb://localhost:27017/lovemarriage_chat

# ── Redis (Upstash / Local) ──────────────────────
# Option A: Upstash connection string
# UPSTASH_REDIS_URL=redis://default:password@host:6379
# Option B: Local Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING_IN_PRODUCTION
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=30d

# ── Resend (Email OTP — Free: 100/day) ───────────
# Sign up at https://resend.com and get your API key
RESEND_API_KEY=
FROM_EMAIL=hello@lovemarriage.app
FROM_NAME=LoveMarriage

# ── Cloudflare R2 (Photo Storage — Free: 10GB) ──
# Sign up at https://dash.cloudflare.com → R2
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=lovemarriage-photos

# ── Encryption ───────────────────────────────────
ENCRYPTION_KEY=default_32_char_key_for_dev_only!
